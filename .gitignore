# Local editor and OS noise
.DS_Store

# Python caches inside synced skills
**/__pycache__/
**/*.pyc

# Keep the repository root on an explicit allowlist
/*
!/.gitignore
!/LICENSE
!/README.md
!/README.zh-CN.md
!/codexctl
!/.codex-dotfiles-id
!/bootstrap/
!/codex/

# Keep bootstrap/ limited to the managed entrypoints and scripts
bootstrap/*
!bootstrap/commit.sh
!bootstrap/common.sh
!bootstrap/import-local.sh
!bootstrap/init.sh
!bootstrap/install-cron.sh
!bootstrap/install.sh
!bootstrap/publish.sh
!bootstrap/render-config.sh
!bootstrap/sync.sh

# Keep codex/ focused on shared config only
codex/*
!codex/.gitkeep
!codex/AGENTS.md
!codex/instruction.md
!codex/config.shared.toml
!codex/rules/
!codex/rules/**
!codex/skills/
!codex/skills/**
